{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.brikbyteos.dev/policy-eval.schema.json",
  "title": "BrikByteOS Phase 0 Successful Policy Evaluation Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "policy_name",
    "policy_version",
    "decision",
    "triggered_rules",
    "reasons"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "policy_name": {
      "type": "string",
      "minLength": 1
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": ["allow", "deny"]
    },
    "triggered_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/codeMessage"
      }
    },
    "reasons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/codeMessage"
      }
    }
  },
  "$defs": {
    "codeMessage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}