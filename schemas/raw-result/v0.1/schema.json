{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.brikbyteos.dev/raw-execution-result/v0.1/schema.json",
  "title": "BrikByteOS Raw Execution Result v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "adapter_name",
    "adapter_type",
    "adapter_version",
    "command",
    "execution_status",
    "started_at",
    "finished_at",
    "duration_ms"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "adapter_name": {
      "type": "string",
      "minLength": 1
    },
    "adapter_type": {
      "type": "string",
      "enum": ["unit", "ui", "performance", "security", "other"]
    },
    "adapter_version": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string"
    },
    "args": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "resolved_binary": {
      "type": "string"
    },
    "execution_status": {
      "type": "string",
      "enum": ["completed", "failed", "timed_out", "unavailable"]
    },
    "exit_code": {
      "type": "integer"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "stdout_path": {
      "type": "string"
    },
    "stderr_path": {
      "type": "string"
    },
    "tool_output_path": {
      "type": "string"
    },
    "error_message": {
      "type": "string"
    }
  }
}