{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.brikbyte.dev/normalized-result/v0/schema.json",
  "title": "BrikByteOS Normalized Result v0",
  "description": "Canonical post-normalization, pre-policy evidence contract for BrikByteOS.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_family",
    "schema_version",
    "adapter_family",
    "normalized_at",
    "issues",
    "metrics",
    "severity_rollup",
    "evidence_completeness"
  ],
  "properties": {
    "schema_family": {
      "type": "string",
      "const": "normalized-result",
      "description": "Stable schema family identity."
    },
    "schema_version": {
      "type": "string",
      "const": "v0",
      "description": "Explicit schema version namespace."
    },
    "adapter_family": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical adapter family or normalized evidence source category, for example security-scan, ui-test, performance-test."
    },
    "adapter_name": {
      "type": "string",
      "minLength": 1,
      "description": "Optional concrete adapter identity when useful after normalization."
    },
    "normalized_at": {
      "type": "string",
      "format": "date-time",
      "description": "RFC3339 timestamp indicating when normalization completed."
    },
    "source_execution_refs": {
      "type": "array",
      "description": "Optional references back to raw execution artifacts or raw-result records.",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "issues": {
      "type": "array",
      "description": "Canonical normalized issue/finding list. May be empty if no findings exist.",
      "items": {
        "$ref": "#/$defs/issue"
      }
    },
    "metrics": {
      "type": "array",
      "description": "Canonical normalized metrics needed for downstream policy evaluation.",
      "items": {
        "$ref": "#/$defs/metric"
      }
    },
    "severity_rollup": {
      "$ref": "#/$defs/severity_rollup"
    },
    "evidence_completeness": {
      "$ref": "#/$defs/evidence_completeness"
    }
  },
  "$defs": {
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1,
          "description": "Reference type, for example raw-result, artifact-path, execution-id."
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "description": "Reference value."
        }
      },
      "description": "Reference to supporting raw evidence without embedding raw execution payload."
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "category",
        "severity",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable normalized issue identifier or source-stable reference."
        },
        "category": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical issue category or type."
        },
        "severity": {
          "type": "string",
          "enum": [
            "critical",
            "high",
            "medium",
            "low",
            "info",
            "unknown"
          ],
          "description": "Canonical normalized severity value."
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable normalized issue summary."
        },
        "location": {
          "type": "string",
          "minLength": 1,
          "description": "Optional normalized location or target reference."
        },
        "evidence_refs": {
          "type": "array",
          "description": "Optional references to supporting raw evidence.",
          "items": {
            "$ref": "#/$defs/reference"
          }
        }
      },
      "description": "Canonical normalized issue model. No policy judgments, AI summaries, or recommendations belong here."
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "kind",
        "value"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical metric name."
        },
        "kind": {
          "type": "string",
          "enum": [
            "integer",
            "number",
            "boolean"
          ],
          "description": "Metric value kind."
        },
        "unit": {
          "type": "string",
          "minLength": 1,
          "description": "Optional metric unit, for example ms, percent, count."
        },
        "value": {
          "description": "Metric value. Type must match the declared kind.",
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "type": "number",
              "not": { "type": "integer" }
            },
            {
              "type": "boolean"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "integer"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "type": "integer"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "number"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "type": "number"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "boolean"
              }
            },
            "required": [
              "kind"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "type": "boolean"
              }
            }
          }
        }
      ],
      "description": "Canonical normalized metric model."
    },
    "severity_rollup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "critical",
        "high",
        "medium",
        "low",
        "info",
        "unknown",
        "total"
      ],
      "properties": {
        "critical": {
          "type": "integer",
          "minimum": 0
        },
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "medium": {
          "type": "integer",
          "minimum": 0
        },
        "low": {
          "type": "integer",
          "minimum": 0
        },
        "info": {
          "type": "integer",
          "minimum": 0
        },
        "unknown": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": "integer",
          "minimum": 0
        }
      },
      "description": "Aggregate normalized severity counts."
    },
    "evidence_completeness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "policy_ready"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "complete",
            "partial",
            "insufficient"
          ],
          "description": "Completeness of normalized evidence."
        },
        "policy_ready": {
          "type": "boolean",
          "description": "Whether the normalized evidence is complete enough for downstream policy evaluation."
        },
        "notes": {
          "type": "string",
          "minLength": 1,
          "description": "Optional human-readable completeness explanation."
        }
      },
      "description": "Explicit evidence completeness semantics, separate from issue counts and severity rollups."
    }
  }
}