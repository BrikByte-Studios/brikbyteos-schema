{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.brikbyteos.dev/audit-manifest/v0.1/schema.json",
  "title": "BrikByteOS Run Manifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "status",
    "started_at",
    "execution_order",
    "adapters",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "in_progress",
        "success",
        "partial_success",
        "failed"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "execution_order": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_selected",
        "total_executed",
        "passed",
        "failed",
        "timed_out",
        "not_found",
        "normalization_failed",
        "duration_ms_total"
      ],
      "properties": {
        "total_selected": {
          "type": "integer",
          "minimum": 0
        },
        "total_executed": {
          "type": "integer",
          "minimum": 0
        },
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "failed": {
          "type": "integer",
          "minimum": 0
        },
        "timed_out": {
          "type": "integer",
          "minimum": 0
        },
        "not_found": {
          "type": "integer",
          "minimum": 0
        },
        "normalization_failed": {
          "type": "integer",
          "minimum": 0
        },
        "duration_ms_total": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "adapters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status",
          "raw_artifacts"
        ],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "failed",
              "timed_out",
              "not_found",
              "normalization_failed"
            ]
          },
          "duration_ms": {
            "type": "integer",
            "minimum": 0
          },
          "normalized_result": {
            "type": "string",
            "minLength": 1
          },
          "raw_artifacts": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "stdout",
              "stderr"
            ],
            "properties": {
              "stdout": {
                "type": "string",
                "minLength": 1
              },
              "stderr": {
                "type": "string",
                "minLength": 1
              },
              "tool_output": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "raw_root": {
          "type": "string",
          "minLength": 1
        },
        "normalized_root": {
          "type": "string",
          "minLength": 1
        },
        "logs_root": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "extensions": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "additionalProperties": {
        "type": "object"
      }
    }
  }
}