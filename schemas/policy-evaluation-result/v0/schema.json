{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.brikbyte.dev/policy-evaluation-result/v0/schema.json",
  "title": "BrikByteOS Policy Evaluation Result v0",
  "description": "Canonical post-policy, pre-verdict contract representing the outcome of evaluating one policy rule against normalized evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_family",
    "schema_version",
    "policy",
    "evaluation"
  ],
  "properties": {
    "schema_family": {
      "type": "string",
      "const": "policy-evaluation-result",
      "description": "Stable schema family identity."
    },
    "schema_version": {
      "type": "string",
      "const": "v0",
      "description": "Explicit schema version namespace."
    },
    "policy": {
      "$ref": "#/$defs/policy_identity"
    },
    "evaluation": {
      "$ref": "#/$defs/evaluation_result"
    }
  },
  "$defs": {
    "policy_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable machine-usable policy identifier."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Optional human-readable policy display name."
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Explicit version of the evaluated policy definition."
        },
        "category": {
          "type": "string",
          "minLength": 1,
          "description": "Optional policy category, for example security, coverage, performance."
        }
      },
      "description": "Stable policy identity. Name alone is never sufficient identity."
    },
    "evaluation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "reason",
        "evaluated_at",
        "evidence_refs"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "not_applicable",
            "error"
          ],
          "description": "Fixed evaluation outcome vocabulary for one policy result."
        },
        "enforcement_level": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "error",
            "critical"
          ],
          "description": "Optional enforcement/violation level of the policy result. This is not the final release verdict."
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "description": "Concise human-readable explanation of why this policy produced this result."
        },
        "evaluated_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC3339 timestamp indicating when the policy evaluation completed."
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/evidence_reference"
          },
          "description": "References to normalized evidence supporting the policy evaluation result."
        },
        "metadata": {
          "type": "object",
          "description": "Optional safe metadata for audit or debugging. Must remain minimal and not become a dumping ground.",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "null"
            ]
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "passed"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "enforcement_level": {
                "enum": [
                  "info",
                  "warning"
                ]
              }
            }
          }
        }
      ],
      "description": "Outcome of evaluating one policy against normalized evidence."
    },
    "evidence_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "normalized-issue",
            "normalized-metric",
            "severity-rollup",
            "evidence-completeness",
            "normalized-result"
          ],
          "description": "Supported evidence reference type cited by the policy result."
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "description": "Reference value identifying the cited evidence."
        },
        "field": {
          "type": "string",
          "minLength": 1,
          "description": "Optional field path or sub-attribute within the referenced evidence object."
        }
      },
      "description": "Reference to supporting normalized evidence. Full evidence payloads are not embedded here."
    }
  }
}